# OpenAI-compatible API key (required).
# OPENAI_API_KEY takes precedence; VISION_API_KEY is a compatibility alias.
OPENAI_API_KEY=sk-your-key-here
# VISION_API_KEY=sk-your-key-here

# Vision model to use (default: gpt-4o-mini).
# Aliases: VISION_MODEL or VISION_MODEL_NAME.
OPENAI_MODEL=gpt-4o-mini
# VISION_MODEL=gpt-4o-mini

# Optional: override API base URL for OpenAI-compatible providers.
# Alias: VISION_BASE_URL.
# OPENAI_BASE_URL=https://api.openai.com/v1
# VISION_BASE_URL=https://api.openai.com/v1

# Request timeout in milliseconds (default: 60000).
# Aliases: VISION_TIMEOUT_MS or VISION_REQUEST_TIMEOUT_MS.
OPENAI_TIMEOUT_MS=60000
# VISION_TIMEOUT_MS=60000

# Local file path input is enabled by default for compatibility.
# Set to false for clipboard/URL/base64-only deployments.
# VISION_ENABLE_LOCAL_PATH_INPUT=true

# Optional comma-separated allowlist for local file paths.
# Empty means any local path is allowed when local path input is enabled.
# Use "*" to allow all paths explicitly.
# VISION_ALLOWED_LOCAL_ROOTS=/Users/me/Pictures,/tmp
