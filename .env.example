# OpenAI-compatible API key (required).
OPENAI_API_KEY=sk-your-key-here

# Vision model to use (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional: override API base URL for OpenAI-compatible providers.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Request timeout in milliseconds (default: 60000).
OPENAI_TIMEOUT_MS=60000

# Local file path input is enabled by default for compatibility.
# Set to false for clipboard/URL/base64-only deployments.
# LOCAL_FILE_INPUT_ENABLED=true

# Optional comma-separated allowlist for local file paths.
# Empty means any local path is allowed when local path input is enabled.
# Use "*" to allow all paths explicitly.
# LOCAL_FILE_ALLOWED_ROOTS=/Users/me/Pictures,/tmp
